{
  "mcpServers": {
    "supabase": {
      "command": "sh",
      "args": [
        "-c",
        "npx -y @supabase/mcp-server-supabase@0.7.0 --project-ref ${SUPABASE_PROJECT_REF:-bdiejmtzlmocxiubahuu}"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github@latest"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    }
  }
}
